# Copy this file to `.env` and fill in values. Do NOT commit your `.env`.
#
# Optional: set an IANA timezone so "today" and Sheet timestamps match your location.
# (PythonAnywhere often runs in UTC. Example for Bangladesh:)
# APP_TIMEZONE=Asia/Dhaka
#
# Google Sheets webhook (Apps Script Web App)
SHEETS_WEBHOOK_URL=PASTE_WEB_APP_URL_HERE
SHEETS_WEBHOOK_TOKEN=PASTE_TOKEN_HERE
# Optional (default 3.0 seconds)
# SHEETS_WEBHOOK_TIMEOUT=6.0
#
# Flask session security (generate your own random string)
# SECRET_KEY=PASTE_RANDOM_SECRET_HERE

# "Keep me logged in" duration (days). Default: 30
# REMEMBER_ME_DAYS=30

# Server-side TTS cache controls (gTTS)
# TTS_CACHE_DIR=data/tts_cache
# TTS_CACHE_MAX_MB=80
# TTS_CACHE_MAX_FILES=5000
# TTS_CACHE_TTL_DAYS=45
# TTS_CACHE_MIN_AGE_SEC=120
# TTS_CACHE_CLEANUP_INTERVAL_SEC=3600
